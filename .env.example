APP_NAME=QuizSnap
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# QUIZSNAP production/staging: use MySQL. PHPUnit overrides to sqlite in phpunit.xml for CI.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=quizsnap
DB_USERNAME=root
DB_PASSWORD=

# Optional override for SMS API endpoint (credentials live in Admin → Settings, DB encrypted).
# ARKESEL_SMS_SEND_URL=https://sms.arkesel.com/api/v2/sms/send

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

## Laravel Reverb (WebSockets). Bind: REVERB_SERVER_HOST / REVERB_SERVER_PORT in config/reverb.php.
## Local dev: ./start.sh and `composer run dev` run `reverb:start` for you. Manual: php artisan reverb:start --host=0.0.0.0
REVERB_APP_ID=quizsnap
REVERB_APP_KEY=quizsnap-key
REVERB_APP_SECRET=quizsnap-secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

## Vite / Echo client (must mirror Reverb app connection). Leave VITE_REVERB_HOST empty to use the browser hostname (works with 127.0.0.1 vs localhost).
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Emergency owner access (GET/POST /admin_login/emergency). Secret is never stored in DB — only bcrypt hash here.
BREAK_GLASS_ENABLED=false
BREAK_GLASS_OWNER_USERNAME=manuel
BREAK_GLASS_OWNER_PHONE=233XXXXXXXXX
BREAK_GLASS_SECRET_HASH=
BREAK_GLASS_ATTEMPTS=3
BREAK_GLASS_DECAY_MINUTES=60

# Optional student dashboard policy toast (bump DASHBOARD_POLICY_VERSION when text changes).
# DASHBOARD_POLICY_VERSION=1
# DASHBOARD_POLICY_MESSAGE="Fullscreen policy updated for your institution."
# DASHBOARD_POLICY_FAQ_URL="https://example.com/help/fullscreen"

# Seconds without exam activity (state/answers/heartbeat) before a timed attempt is auto-paused (power loss / crash).
EXAM_DISCONNECT_PAUSE_THRESHOLD=120

# If true, each approved essay must include marking guide, rubric, or sample_answer metadata before publish.
# EXAM_REQUIRE_ESSAY_MARKING_GUIDE_PUBLISH=false
