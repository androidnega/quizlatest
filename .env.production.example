# QUIZSNAP — staging / production rehearsal template
# Copy to .env on the server (never commit .env). Replace ALL placeholders.
# Generate APP_KEY: php artisan key:generate --show  (then set APP_KEY=...)

APP_NAME=QUIZSNAP
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://quizsnap.example.edu

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Database (MySQL required for production) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=quizsnap
DB_USERNAME=quizsnap_app
DB_PASSWORD=
# DB_URL=mysql://user:pass@host:3306/database
# MYSQL_ATTR_SSL_CA=/path/to/ca.pem

# --- Session / cookies (harden for HTTPS) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.example.edu
SESSION_SECURE_COOKIE=true

# --- Broadcasting (Reverb) — browser build must match (VITE_*) ---
BROADCAST_CONNECTION=reverb

# Server-side Reverb app credentials (use long random strings; not committed here)
REVERB_APP_ID=quizsnap-prod
REVERB_APP_KEY=change-me-reverb-public-key
REVERB_APP_SECRET=change-me-reverb-secret
REVERB_HOST=ws.quizsnap.example.edu
REVERB_PORT=443
REVERB_SCHEME=https

# Reverb process bind (often 0.0.0.0 behind reverse proxy)
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
VITE_APP_NAME="${APP_NAME}"

# --- Queue (database driver is fine if you run queue workers when jobs exist) ---
QUEUE_CONNECTION=database
# DB_QUEUE_CONNECTION=
# DB_QUEUE_TABLE=jobs

# --- Cache ---
CACHE_STORE=database
# For higher load after validation: CACHE_STORE=redis

# --- Redis (optional on cPanel — Admin → System settings → Infrastructure can disable Redis
#     and allow cache/DB fallbacks; see docs/deployment/DEPLOYMENT_CHECKLIST.md § cPanel) ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://:password@127.0.0.1:6379/0
# REDIS_USERNAME=
# REDIS_CACHE_DB=1

# --- Exam OTP (Redis primary; optional cache fallback) ---
# When false and Redis is down, OTP-related flows fail closed (503 / service unavailable).
EXAM_OTP_FALLBACK_ENABLED=false
EXAM_OTP_FALLBACK_CACHE_STORE=file

# --- Filesystem ---
# "local" maps to private storage (storage/app/private) in this project.
FILESYSTEM_DISK=local

# --- Mail (set real transport for production) ---
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.edu
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@example.edu"
MAIL_FROM_NAME="${APP_NAME}"

# --- SMS (Arkesel) ---
# Endpoint only. API keys and sender IDs are stored in Admin → System Settings (encrypted in DB), not in .env.
# ARKESEL_SMS_SEND_URL=https://sms.arkesel.com/api/v2/sms/send

# --- AI (practice module / exam builder integrations) ---
# Provider keys and model names are configured via Admin → System Settings where applicable — not plain .env secrets.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
